<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/main"
    android:orientation="vertical"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    tools:context=".OTTActivity">

    <TextView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="OTT Platforms"
        android:textAlignment="center"
        android:textSize="20sp"
        android:textStyle="bold"
        android:textColor="@color/black"
        android:padding="10dp"/>

    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="match_parent">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical">

            <ImageView
                android:id="@+id/iv_hotstar"
                android:layout_width="match_parent"
                android:layout_height="150dp"
                android:layout_margin="10dp"
                android:src="@drawable/jiohotsarlogo" />

            <ImageView
                android:id="@+id/iv_sonyliv"
                android:layout_width="match_parent"
                android:layout_height="150dp"
                android:layout_margin="10dp"
                android:src="@drawable/sonylivlogo" />

            <ImageView
                android:id="@+id/iv_youtube"
                android:layout_width="match_parent"
                android:layout_height="150dp"
                android:layout_margin="10dp"
                android:src="@drawable/youtubelogo" />

            <ImageView
                android:id="@+id/iv_amazon_prime_video"
                android:layout_width="match_parent"
                android:layout_height="100dp"
                android:layout_margin="10dp"
                android:src="@drawable/amazon_prime_video_logo" />

            <ImageView
                android:id="@+id/ivMXPlayer"
                android:layout_width="match_parent"
                android:layout_height="100dp"
                android:layout_margin="10dp"
                android:src="@drawable/mx_player_logo_svg" />

            <ImageView
                android:id="@+id/iv_zee5"
                android:layout_width="match_parent"
                android:layout_height="100dp"
                android:layout_margin="10dp"
                android:src="@drawable/zee5logo" />

            <ImageView
                android:id="@+id/iv_netflix"
                android:layout_width="match_parent"
                android:layout_height="100dp"
                android:layout_margin="10dp"
                android:src="@drawable/netflixlogo" />

            <TextView
                android:background="@drawable/shape"
                android:textColor="#ff0000"
                android:id="@+id/tvExploreFurtherClickHere"
                android:layout_width="match_parent"
                android:text="Explore further click here !"
                android:textStyle="bold"
                android:layout_marginTop="10dp"
                android:textAlignment="center"
                android:textSize="25sp"
                android:gravity="center"
                android:layout_height="50dp"/>

        </LinearLayout>

    </ScrollView>

</LinearLayout>