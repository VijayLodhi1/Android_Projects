<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/main"
    android:orientation="vertical"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    tools:context=".MainActivity">

    <LinearLayout
        android:background="#0076CE"
        android:gravity="center"
        android:layout_width="412dp"
        android:layout_height="125dp">

        <TextView
            android:textSize="25sp"
            android:textStyle="bold"
            android:text="Converter"
            android:textColor="#ffffff"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"/>

    </LinearLayout>

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:orientation="vertical">

        <TextView
            android:layout_width="290dp"
            android:layout_height="38dp"
            android:gravity="center"
            android:layout_marginTop="10dp"
            android:text="Number System Converter"
            android:textColor="#000000"
            android:textSize="20sp"
            android:textStyle="normal"
            android:layout_gravity="center"/>

        <LinearLayout
            android:padding="5dp"
            android:layout_margin="5dp"
            android:layout_width="match_parent"
            android:layout_height="wrap_content">

            <TextView
                android:layout_width="67dp"
                android:layout_height="35dp"
                android:layout_marginLeft="50dp"
                android:layout_marginTop="10dp"
                android:text="FROM : "
                android:textColor="#000000"
                android:textSize="20sp"
                android:textStyle="normal" />

            <Spinner
                android:layout_marginTop="10dp"
                android:layout_marginLeft="10dp"
                android:id="@+id/spinner_from"
                android:entries="@array/from_spinner_values"
                android:layout_width="240dp"
                android:layout_height="40dp" />

        </LinearLayout>

        <LinearLayout
            android:padding="5dp"
            android:layout_margin="5dp"
            android:layout_width="match_parent"
            android:layout_height="wrap_content">

            <TextView
                android:layout_width="36dp"
                android:layout_height="36dp"
                android:layout_marginLeft="50dp"
                android:layout_marginTop="10dp"
                android:text="To : "
                android:textColor="#000000"
                android:textSize="20sp"
                android:textStyle="normal" />

            <Spinner
                android:layout_marginTop="10dp"
                android:layout_marginLeft="42dp"
                android:id="@+id/spinner_to"
                android:entries="@array/to_spinner_values"
                android:layout_width="240dp"
                android:layout_height="40dp" />

        </LinearLayout>

        <EditText
            android:id="@+id/et_entered_number"
            android:hint="Enter number"
            android:textSize="20sp"
            android:background="@drawable/shape1"
            android:inputType="text"
            android:textColor="#54545657"
            android:layout_marginTop="10dp"
            android:layout_gravity="center"
            android:layout_width="314dp"
            android:layout_height="40dp"/>

        <Button
            android:id="@+id/btn_convert"
            android:text="Convert"
            android:textSize="20sp"
            android:background="@drawable/btn_shape"
            android:textColor="#ffffff"
            android:layout_gravity="center"
            android:layout_marginTop="20dp"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"/>

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="20dp"
            android:text="Converted Code"
            android:textColor="#000000"
            android:textSize="20sp"
            android:textStyle="bold"
            android:layout_gravity="center"/>

        <TextView
            android:id="@+id/tv_converted_number"
            android:layout_width="324dp"
            android:layout_height="177dp"
            android:layout_marginTop="20dp"
            android:hint="Example : 0101011001"
            android:gravity="center"
            android:textColor="#000000"
            android:textSize="20sp"
            android:textStyle="normal"
            android:layout_gravity="center"
            android:background="@drawable/shape"/>

        <TextView
            android:textSize="10sp"
            android:textStyle="normal"
            android:layout_gravity="center"
            android:gravity="center"
            android:text="Copyright © 2025 Converter Inc."
            android:textColor="#000000"
            android:layout_marginTop="10dp"
            android:layout_width="271dp"
            android:layout_height="41dp"/>

    </LinearLayout>

</LinearLayout>